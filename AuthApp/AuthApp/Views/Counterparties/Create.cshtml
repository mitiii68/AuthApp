@model AuthApp.Models.Counterparty
@{
    ViewData["Title"] = "Добавление контрагента";
}

<style>
    .form-page {
        padding: 32px;
        max-width: 960px;
    }
    .form-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
    }
    .form-header a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 14px;
    }
    .form-header a:hover { color: var(--blue); }
    .form-header span { color: var(--border); }
    .form-title {
        font-size: 22px;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }
    .form-card {
        background: var(--white);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        margin-bottom: 16px;
    }
    .form-card-header {
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
        background: var(--bg);
    }
    .form-card-body {
        padding: 24px;
    }
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .form-group label {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-muted);
    }
    .form-group label span {
        color: #dc2626;
    }
    .form-control-custom {
        padding: 9px 12px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-family: 'Golos Text', sans-serif;
        color: var(--text);
        background: var(--white);
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
    }
    .form-control-custom:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(26,111,212,0.1);
    }
    .form-actions {
        display: flex;
        gap: 10px;
        padding: 20px 24px;
        border-top: 1px solid var(--border);
        background: var(--bg);
    }
    .btn-save {
        background: var(--blue);
        color: white;
        border: none;
        padding: 9px 24px;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 500;
        font-family: 'Golos Text', sans-serif;
        cursor: pointer;
        transition: background 0.15s;
    }
    .btn-save:hover { background: var(--blue-dark); }
    .btn-cancel {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border);
        padding: 9px 20px;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s;
    }
    .btn-cancel:hover {
        border-color: var(--blue);
        color: var(--blue);
    }
    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 0;
    }
    .checkbox-group input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: var(--blue);
    }
    .checkbox-group label {
        font-size: 14px;
        color: var(--text);
        margin: 0;
    }
</style>

<div class="form-page">
    <div class="form-header">
        <a asp-action="Index">← Контрагенты</a>
        <span>/</span>
        <h1 class="form-title">Добавление контрагента</h1>
    </div>

    <form method="post">
        <!-- Основная информация -->
        <div class="form-card">
            <div class="form-card-header">Основная информация</div>
            <div class="form-card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Контрагент <span>*</span></label>
                        <input asp-for="Name" class="form-control-custom" placeholder="Название контрагента" />
                    </div>
                    <div class="form-group">
                        <label>Краткое название</label>
                        <input asp-for="ShortName" class="form-control-custom" placeholder="Краткое название" />
                    </div>
                    <div class="form-group">
                        <label>ИИН/БИН <span>*</span></label>
                        <input asp-for="IinBin" class="form-control-custom" />
                        <span asp-validation-for="IinBin" style="color:#dc2626; font-size:12px;"></span>
                    </div>
                    <div class="form-group">
                        <label>Тип</label>
                        <select asp-for="Type" asp-items="ViewBag.TypeList" class="form-control-custom">
                            <option value="">Выберите опцию</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Отрасль</label>
                        <select asp-for="Industry" asp-items="ViewBag.IndustryList" class="form-control-custom">
                            <option value="">Выберите опцию</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Тип организации</label>
                        <select asp-for="OrganizationType" asp-items="ViewBag.OrganizationTypeList" class="form-control-custom">
                            <option value="">Выберите опцию</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Контакты -->
        <div class="form-card">
            <div class="form-card-header">Контакты</div>
            <div class="form-card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Основной телефон</label>
                        <input asp-for="MainPhone" class="form-control-custom" placeholder="+7 (000) 000-00-00" />
                    </div>
                    <div class="form-group">
                        <label>Другой телефон</label>
                        <input asp-for="OtherPhone" class="form-control-custom" placeholder="+7 (000) 000-00-00" />
                    </div>
                    <div class="form-group">
                        <label>Основной Email</label>
                        <input asp-for="MainEmail" class="form-control-custom" placeholder="email@example.com" />
                    </div>
                    <div class="form-group">
                        <label>Факс</label>
                        <input asp-for="Fax" class="form-control-custom" placeholder="Факс" />
                    </div>
                    <div class="form-group">
                        <label>Веб-сайт</label>
                        <input asp-for="Website" class="form-control-custom" placeholder="https://example.com" />
                    </div>
                    <div class="form-group">
                        <div class="checkbox-group">
                            <input asp-for="DoNotSendEmail" type="checkbox" />
                            <label>Не отправлять E-mail</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Соцсети -->
        <div class="form-card">
            <div class="form-card-header">Социальные сети</div>
            <div class="form-card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Facebook URL</label>
                        <input asp-for="FacebookUrl" class="form-control-custom" placeholder="https://facebook.com/..." />
                    </div>
                    <div class="form-group">
                        <label>Vkontakte URL</label>
                        <input asp-for="VkontakteUrl" class="form-control-custom" placeholder="https://vk.com/..." />
                    </div>
                    <div class="form-group">
                        <label>Twitter URL</label>
                        <input asp-for="TwitterUrl" class="form-control-custom" placeholder="https://twitter.com/..." />
                    </div>
                </div>
            </div>
        </div>

        <!-- Адрес -->
        <div class="form-card">
            <div class="form-card-header">Адрес</div>
            <div class="form-card-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Юридический адрес</label>
                        <textarea asp-for="LegalAddress" class="form-control-custom" rows="3" placeholder="Юридический адрес"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Фактический адрес</label>
                        <textarea asp-for="ActualAddress" class="form-control-custom" rows="3" placeholder="Фактический адрес"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Страна</label>
                        <input asp-for="Country" class="form-control-custom" placeholder="Страна" />
                    </div>
                    <div class="form-group">
                        <label>Ф/А Страна</label>
                        <input asp-for="ActualCountry" class="form-control-custom" placeholder="Страна" />
                    </div>
                    <div class="form-group">
                        <label>Область</label>
                        <input asp-for="Region" class="form-control-custom" placeholder="Область" />
                    </div>
                    <div class="form-group">
                        <label>Ф/А Область</label>
                        <input asp-for="ActualRegion" class="form-control-custom" placeholder="Область" />
                    </div>
                    <div class="form-group">
                        <label>Город</label>
                        <input asp-for="City" class="form-control-custom" placeholder="Город" />
                    </div>
                    <div class="form-group">
                        <label>Ф/А Город</label>
                        <input asp-for="ActualCity" class="form-control-custom" placeholder="Город" />
                    </div>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save">Сохранить</button>
            <a asp-action="Index" class="btn-cancel">Отмена</a>
        </div>
    </form>
</div>

<script>

    function phoneMask(input) {
            input.addEventListener('input', function () {
                let val = this.value.replace(/\D/g, '');
                if (val.startsWith('8')) val = '7' + val.slice(1);
                if (!val.startsWith('7')) val = '7' + val;
                val = val.slice(0, 11);

                let result = '+7';
                if (val.length > 1) result += ' (' + val.slice(1, 4);
                if (val.length >= 4) result += ') ' + val.slice(4, 7);
                if (val.length >= 7) result += ' ' + val.slice(7, 9);
                if (val.length >= 9) result += ' ' + val.slice(9, 11);

                this.value = result;
            });

            input.addEventListener('keydown', function (e) {
                if (e.key === 'Backspace' && this.value === '+7') {
                    e.preventDefault();
                }
            });

            input.addEventListener('focus', function () {
                if (!this.value) this.value = '+7';
            });
        }

    
        function iinMask(input) {
            input.addEventListener('input', function () {
                let val = this.value.replace(/\D/g, '').slice(0, 12);
                let result = '';
                for (let i = 0; i < val.length; i++) {
                    if (i > 0 && i % 3 === 0) result += ' ';
                    result += val[i];
                }
                this.value = result;
            });
        }

        
        document.querySelectorAll('input[name="MainPhone"], input[name="OtherPhone"]')
            .forEach(phoneMask);

        document.querySelectorAll('input[name="IinBin"]')
            .forEach(iinMask);
    </script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
