@model List<TagCategory>
@{
    ViewData["Title"] = "Категории тегов";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@@400;500;600;700;800&display=swap');

    :root {
        --accent:       #3b5bdb;
        --accent-light: #e7ecfd;
        --accent-hover: #2f4ac7;
        --surface:      #ffffff;
        --surface-2:    #f8f9fc;
        --border:       #e3e8f0;
        --text:         #1a1d2e;
        --text-sub:     #6b7280;
        --danger:       #e03131;
        --danger-light: #fff0f0;
        --shadow-sm:    0 1px 4px rgba(59,91,219,.08);
        --shadow-md:    0 4px 24px rgba(59,91,219,.13);
        --radius:       12px;
        --font:         'Nunito', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font); color: var(--text); background: var(--surface-2); }

    .docs-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
    }
    .docs-header h1 { font-size: 26px; font-weight: 800; letter-spacing: -.4px; line-height: 1.2; }
    .docs-header p  { font-size: 14px; color: var(--text-sub); margin-top: 3px; font-weight: 500; }

    .btn {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 18px; border-radius: 8px; font-family: var(--font);
        font-size: 14px; font-weight: 700; cursor: pointer; border: none;
        text-decoration: none; transition: background .15s, transform .1s; white-space: nowrap;
    }
    .btn:active { transform: scale(.98); }
    .btn-primary { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(59,91,219,.25); }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-ghost { background: var(--surface); color: var(--text); border: 1.5px solid var(--border); }
    .btn-ghost:hover { background: var(--surface-2); }
    .btn-sm { padding: 7px 14px; font-size: 13px; }

    .add-form-card {
        background: var(--surface); border: 1.5px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow-md);
        margin-bottom: 20px; overflow: hidden;
    }
    .add-form-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px; border-bottom: 1.5px solid var(--border);
        font-size: 14px; font-weight: 700; background: var(--surface-2);
    }
    .btn-close-x {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px; border-radius: 6px; border: none;
        background: transparent; color: var(--text-sub); cursor: pointer;
        transition: background .12s, color .12s;
    }
    .btn-close-x:hover { background: var(--danger-light); color: var(--danger); }

    .add-form-body { padding: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; max-width: 420px; }
    .form-label { font-size: 12.5px; font-weight: 700; color: var(--text-sub); text-transform: uppercase; letter-spacing: .05em; }
    .form-input {
        padding: 9px 13px; border-radius: 8px; border: 1.5px solid var(--border);
        font-family: var(--font); font-size: 14px; font-weight: 500;
        color: var(--text); background: var(--surface);
        transition: border-color .15s, box-shadow .15s; outline: none; width: 100%;
    }
    .form-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-light); }

    .form-footer {
        display: flex; justify-content: flex-end; gap: 10px;
        margin-top: 18px; padding-top: 16px; border-top: 1.5px solid var(--border);
    }

    .card {
        background: var(--surface); border: 1.5px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden;
    }
    .card-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px; border-bottom: 1.5px solid var(--border);
        font-size: 13.5px; font-weight: 600; color: var(--text-sub); background: var(--surface-2);
    }
    .card-header strong { color: var(--text); font-weight: 800; }

    .empty-state {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 64px 20px;
        color: var(--text-sub); gap: 12px; text-align: center;
    }
    .empty-state svg { opacity: .3; }
    .empty-state p { font-size: 16px; font-weight: 700; color: var(--text); }

    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .data-table thead th {
        padding: 11px 16px; background: var(--surface-2);
        font-size: 11.5px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .07em; color: var(--text-sub);
        border-bottom: 1.5px solid var(--border); text-align: left;
    }
    .data-table thead th.th-right { text-align: right; }
    .data-table tbody tr { border-bottom: 1px solid var(--border); transition: background .12s; }
    .data-table tbody tr:last-child { border-bottom: none; }
    .data-table tbody tr:hover { background: #f4f6ff; }
    .data-table td { padding: 11px 16px; vertical-align: middle; }
    .td-muted { color: var(--text-sub); font-size: 13px; font-weight: 600; width: 56px; }
    .td-right { text-align: right; }

    
    .inline-edit {
        display: flex; align-items: center; gap: 10px;
    }
    .inline-edit .form-input {
        width: 240px; padding: 7px 11px; font-size: 13.5px;
    }

    
    .btn-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 34px; height: 34px; border-radius: 8px;
        border: 1.5px solid var(--border); background: var(--surface);
        color: var(--text-sub); cursor: pointer;
        transition: background .12s, border-color .12s, color .12s;
    }
    .btn-icon.danger:hover { background: var(--danger-light); border-color: var(--danger); color: var(--danger); }

    
    .search-panel {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        padding: 14px 18px;
        margin-bottom: 18px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: flex-end;
    }
    .search-field { flex: 1 1 220px; }
    .sort-field   { flex: 0 1 180px; }
    .search-label {
        display: block;
        font-size: 11.5px; font-weight: 700; color: var(--text-sub);
        text-transform: uppercase; letter-spacing: .06em; margin-bottom: 5px;
    }
    .search-input-wrap { position: relative; }
    .search-input-wrap svg {
        position: absolute; left: 10px; top: 50%;
        transform: translateY(-50%); color: var(--text-sub); pointer-events: none;
    }
    .search-input {
        width: 100%; padding: 8px 12px 8px 34px;
        border: 1.5px solid var(--border); border-radius: 8px;
        font-family: var(--font); font-size: 14px; font-weight: 500;
        color: var(--text); background: var(--surface-2); outline: none;
        transition: border-color .15s, box-shadow .15s, background .15s;
    }
    .search-input:focus {
        border-color: var(--accent); background: var(--surface);
        box-shadow: 0 0 0 3px var(--accent-light);
    }
    .sort-select {
        width: 100%; padding: 8px 32px 8px 12px;
        border: 1.5px solid var(--border); border-radius: 8px;
        font-family: var(--font); font-size: 14px; font-weight: 500;
        color: var(--text); background: var(--surface-2); outline: none;
        cursor: pointer; appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 24 24' fill='none' stroke='%236b7280' stroke-width='2.5' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='6 9 12 15 18 9'/%3E%3C/svg%3E");
        background-repeat: no-repeat; background-position: right 10px center;
        transition: border-color .15s, box-shadow .15s;
    }
    .sort-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-light); }
    .no-results-row td {
        text-align: center; padding: 40px 20px;
        color: var(--text-sub); font-size: 14px; font-weight: 600;
    }

</style>


<div class="docs-header">
    <div>
        <h1>Категории тегов</h1>
        <p>Управление категориями для классификации документов</p>
    </div>
    <button class="btn btn-primary" onclick="toggleForm()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Добавить категорию
    </button>
</div>


<div class="add-form-card" id="addForm" style="display:none">
    <div class="add-form-header">
        <span>Новая категория</span>
        <button class="btn-close-x" onclick="toggleForm()" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="add-form-body">
        <form asp-action="Create" method="post">
            <div class="form-group">
                <label class="form-label">Название категории</label>
                <input type="text" name="name" placeholder="Например: Финансовые документы" required class="form-input" />
            </div>
            <div class="form-footer">
                <button type="button" class="btn btn-ghost" onclick="toggleForm()">Отмена</button>
                <button type="submit" class="btn btn-primary">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Сохранить
                </button>
            </div>
        </form>
    </div>
</div>

<div class="search-panel">
    <div class="search-field">
        <label class="search-label" for="catSearch">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:2px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Поиск
        </label>
        <div class="search-input-wrap">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="catSearch" type="text" class="search-input" placeholder="Название категории..." autocomplete="off" />
        </div>
    </div>
    <div class="sort-field">
        <label class="search-label" for="catSort">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:2px"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            Сортировка
        </label>
        <select id="catSort" class="sort-select">
            <option value="az">По имени A–Z</option>
            <option value="za">По имени Z–A</option>
            <option value="id_asc">Сначала старые</option>
            <option value="id_desc">Сначала новые</option>
        </select>
    </div>
    <div style="display:flex;align-items:flex-end;flex-shrink:0">
        <button type="button" id="resetFilters" class="btn btn-ghost btn-sm" style="display:none">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Сбросить
        </button>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span>Показано: <strong id="catCount">@Model.Count</strong> из @Model.Count</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            <p>Категорий пока нет</p>
            <span>Нажмите «Добавить категорию» чтобы создать первую</span>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:56px">#</th>
                    <th>Название категории</th>
                    <th style="width:80px" class="th-right">Удалить</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr data-name="@(cat.Name?.ToLower() ?? "")" data-id="@cat.Id">
                        <td class="td-muted">@cat.Id</td>
                        <td>
                            <form asp-action="Edit" method="post" class="inline-edit">
                                <input type="hidden" name="id" value="@cat.Id" />
                                <input type="text" name="name" value="@cat.Name" class="form-input" required />
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Сохранить
                                </button>
                            </form>
                        </td>
                        <td class="td-right">
                            <form asp-action="Delete" method="post" style="display:inline"
                                  onsubmit="return confirm('Удалить категорию «@cat.Name»?')">
                                <input type="hidden" name="id" value="@cat.Id" />
                                <button type="submit" class="btn-icon danger" title="Удалить">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                                        <path d="M10 11v6M14 11v6M9 6V4h6v2"/>
                                    </svg>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script>
function toggleForm() {
    const f = document.getElementById('addForm');
    f.style.display = f.style.display === 'none' ? 'block' : 'none';
    if (f.style.display === 'block') f.querySelector('input[type="text"]').focus();
}

(function() {
    const searchInput = document.getElementById('catSearch');
    const sortSelect  = document.getElementById('catSort');
    const resetBtn    = document.getElementById('resetFilters');
    const countEl     = document.getElementById('catCount');
    const tbody       = document.querySelector('.data-table tbody');

    if (!tbody || !searchInput) return;

    function getRows() {
        return Array.from(tbody.querySelectorAll('tr[data-name]'));
    }

    function applyFilters() {
        const search = searchInput.value.trim().toLowerCase();
        const sort   = sortSelect ? sortSelect.value : 'az';

        let rows = getRows();


        rows.forEach(row => {
            const name = row.getAttribute('data-name') || '';
            row.style.display = (!search || name.includes(search)) ? '' : 'none';
        });

        
        const visible = rows.filter(r => r.style.display !== 'none');
        visible.sort((a, b) => {
            const nameA = a.getAttribute('data-name') || '';
            const nameB = b.getAttribute('data-name') || '';
            const idA   = parseInt(a.getAttribute('data-id') || '0');
            const idB   = parseInt(b.getAttribute('data-id') || '0');
            switch (sort) {
                case 'za':       return nameB.localeCompare(nameA, 'ru');
                case 'id_asc':   return idA - idB;
                case 'id_desc':  return idB - idA;
                default:         return nameA.localeCompare(nameB, 'ru');
            }
        });
        visible.forEach(row => tbody.appendChild(row));

        
        if (countEl) countEl.textContent = visible.length;

       
        let noRow = tbody.querySelector('.no-results-row');
        if (visible.length === 0) {
            if (!noRow) {
                noRow = document.createElement('tr');
                noRow.className = 'no-results-row';
                const cols = tbody.closest('table').querySelectorAll('thead th').length;
                noRow.innerHTML = `<td colspan="${cols}">Категории не найдены — попробуйте изменить запрос</td>`;
                tbody.appendChild(noRow);
            }
        } else {
            if (noRow) noRow.remove();
        }

       
        if (resetBtn) resetBtn.style.display = search ? 'inline-flex' : 'none';
    }

    searchInput.addEventListener('input', applyFilters);
    if (sortSelect) sortSelect.addEventListener('change', applyFilters);
    if (resetBtn) {
        resetBtn.addEventListener('click', function() {
            searchInput.value = '';
            applyFilters();
        });
    }

    applyFilters();
})();

</script>
