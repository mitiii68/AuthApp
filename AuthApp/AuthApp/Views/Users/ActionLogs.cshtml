@model List<AuthApp.Models.UserActionLog>

@{
    ViewData["Title"] = "История действий";
}

<style>
    .logs-page {
        max-width: 1100px;
        margin: 32px auto;
        padding: 0 16px;
    }

    .logs-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .logs-header {
        padding: 20px 24px;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
    }

    .logs-title {
        margin: 0;
        font-size: 26px;
        font-weight: 700;
        color: #1a1a2e;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 38px;
        padding: 0 18px;
        border-radius: 8px;
        font-family: 'Golos Text', sans-serif;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #1a1a2e;
        transition: all 0.15s;
    }
    .btn-back:hover {
        border-color: #1a6fd4;
        color: #1a6fd4;
        background: #e8f1fc;
    }
    .btn-back::before {
        content: '\2190';
        font-size: 15px;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .logs-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 600px;
    }

    .logs-table th {
        background: #f8fafc;
        color: #374151;
        font-size: 13px;
        font-weight: 600;
        text-align: left;
        padding: 14px 20px;
        border-bottom: 1px solid #e5e7eb;
    }

    .logs-table td {
        padding: 13px 20px;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
        color: #1f2937;
        vertical-align: middle;
    }

    .logs-table tr:last-child td { border-bottom: none; }
    .logs-table tr:hover td { background: #f9fbff; }

    .log-id { color: #9ca3af; font-size: 13px; }
    .log-email { color: #1a6fd4; font-size: 13px; }
    .log-date { font-size: 13px; color: #6b7280; white-space: nowrap; }

    .action-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }
    .action-login  { background: #dcfce7; color: #15803d; }
    .action-delete { background: #fee2e2; color: #b91c1c; }
    .action-change { background: #dbeafe; color: #1d4ed8; }
    .action-default { background: #f3f4f6; color: #374151; }

    .logs-empty {
        text-align: center;
        padding: 48px 24px;
        color: #9ca3af;
        font-size: 14px;
    }
</style>

<div class="logs-page">
    <div class="logs-card">
        <div class="logs-header">
            <h2 class="logs-title">История действий</h2>
            <a asp-controller="Users" asp-action="Index" class="btn-back">Назад к пользователям</a>
        </div>

        <div class="table-wrap">
            @if (Model != null && Model.Count > 0)
            {
                <table class="logs-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Действие</th>
                            <th>Дата</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td class="log-id">@log.Id</td>
                                <td class="log-email">@log.UserEmail</td>
                                <td>
                                    @{
                                        var action = log.Action ?? "";
                                        var badgeClass = "action-default";
                                        if (action.ToLower().Contains("вход") || action.ToLower() == "login")
                                            badgeClass = "action-login";
                                        else if (action.ToLower().Contains("удал"))
                                            badgeClass = "action-delete";
                                        else if (action.ToLower().Contains("изменил") || action.ToLower().Contains("пароль") || action.ToLower().Contains("роль"))
                                            badgeClass = "action-change";
                                    }
                                    <span class="action-badge @badgeClass">@log.Action</span>
                                </td>
                                <td class="log-date">@log.ActionTime.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="logs-empty">История действий пуста</div>
            }
        </div>
    </div>
</div>