@{
    ViewData["Title"] = "Главная";
}

<div class="home-page">
    <h1>Главная страница</h1>
    <p>Добро пожаловать в AuthApp</p>
</div>

@if (ViewBag.ShowWelcome != null && ViewBag.ShowWelcome == true)
{
    <div id="welcomeToast" class="welcome-toast">
        👋 Добро пожаловать, @(ViewBag.UserName ?? "пользователь")!
    </div>
    
}

<style>
    .welcome-toast {
        position: fixed;
        top: 80px;
        right: 20px;
        background: #1d6fd6;
        color: white;
        padding: 16px 20px;
        border-radius: 10px;
        font-weight: 600;
        box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        opacity: 0;
        transform: translateY(-15px);
        transition: all 0.4s ease;
        z-index: 9999;
    }

        .welcome-toast.show {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<script>
    const toast = document.getElementById("welcomeToast");

    if (toast) {
        setTimeout(() => {
            toast.classList.add("show");
        }, 300);

        setTimeout(() => {
            toast.classList.remove("show");
        }, 3500);
    }
</script>