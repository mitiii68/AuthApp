@model List<AuthApp.Models.Role>

@{
    ViewData["Title"] = "Роли";
}
<style>
    .roles-page {
        max-width: 900px;
        margin: 32px auto;
        padding: 0 16px;
    }
    .roles-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        overflow: hidden;
    }
    .roles-header{
        padding:20px 24px;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }
    .roles-title{
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #1a1a2e;
    }
    .roles-subtitle {
        margin-top: 6px;
        font-size: 14px;
        color: #6b7280;
    }
    .roles-table {
        width: 100%;
        border-collapse: collapse;
    }
    .roles-table th {
        background: #f8fafc;
        color: #374151;
        font-size: 13px;
        font-weight: 600;
        text-align: left;
        padding: 14px 16px;
        border-bottom: 1px solid #e5e7eb;
    }
    .roles-table td {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14px;
        color: #1f2937;
        vertical-align: middle;
    }
    .roles-table tr:hover {
        background: #f9fbff;
    }
    .role-badge{
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }
    .role-admin {
        background: #fee2e2;
        color: #b91c1c;
    }
    .role-user {
        background: #dcfce7;
        color: #15803d;
    }
</style>
<div class="roles-page">
    <div class="roles-card">
        <div class="roles-header">
            <h2 class="roles-title">Роли</h2>
            <div class="roles-subtitle">Список ролей, доступных в системе</div>
        </div>

        <table class="roles-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название роли</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model)
                {
                    <tr>
                        <td>@role.RoleId</td>
                        <td>
                            @if (role.RoleName == "Admin")
                            {
                                <span class="role-badge role-admin">Admin</span>
                            }
                            else
                            {
                                <span class="role-badge role-user">User</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
