@model AuthApp.Models.User

@{
    ViewData["Title"] = "Профиль";
}

<div class="profile-page">

    <div class="profile-hero">
        <div class="profile-avatar">
            @(Model.FullName != null ? Model.FullName.Substring(0, 1).ToUpper() : "U")
        </div>

        <div>
            <h2>Добро пожаловать, @(Model.FullName ?? "Пользователь")!</h2>
            <p>Информация о вашем аккаунте</p>
        </div>
    </div>

    <div class="profile-grid">

        <div class="profile-card">
            <span>ФИО</span>
            <strong>@(Model.FullName ?? "—")</strong>
        </div>

        <div class="profile-card">
            <span>Email</span>
            <strong>@(Model.Email ?? "—")</strong>
        </div>

        <div class="profile-card">
            <span>Логин</span>
            <strong>@(Model.Login ?? "—")</strong>
        </div>

        <div class="profile-card">
            <span>Роль</span>
            <strong>@(Model.Role?.RoleName ?? "User")</strong>
        </div>

        <div class="profile-card">
            <span>Дата регистрации</span>
            <strong>@Model.CreateAt.ToString("dd.MM.yyyy HH:mm")</strong>
        </div>

        <div class="profile-card">
            <span>Количество входов</span>
            <strong>@Model.LoginCount</strong>
        </div>

        <div class="profile-card">
            <span>Статус аккаунта</span>

            @if (Model.IsBlocked)
            {
                <strong class="status-bad">● Заблокирован</strong>
            }
            else
            {
                <strong class="status-good">● Активен</strong>
            }
        </div>

        <div class="profile-card">
            <span>Пароль</span>
            <div class="password-row">
                <strong>••••••••</strong>
                <a asp-controller="Account" asp-action="ForgotPassword" class="profile-btn">
                     Сменить
                </a>
            </div>
        </div>

    </div>
</div>
<style>
    .profile-page {
        max-width: 1000px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .profile-hero {
        background: white;
        border: 1px solid #dfe3ea;
        border-radius: 14px;
        padding: 32px;
        display: flex;
        align-items: center;
        gap: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        margin-bottom: 24px;
    }

    .profile-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: #e8f1ff;
        color: #1d6fd6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 700;
        border: 2px solid #bfd8ff;
    }

    .profile-hero h2 {
        margin: 0;
        font-size: 26px;
        color: #111827;
    }

    .profile-hero p {
        margin: 8px 0 0;
        color: #6b7280;
    }

    .profile-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .profile-card {
        background: white;
        border: 1px solid #dfe3ea;
        border-radius: 12px;
        padding: 22px 26px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }

        .profile-card span {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .profile-card strong {
            font-size: 17px;
            color: #1f2937;
        }

    .status-good {
        color: #16a34a !important;
        background: #dcfce7;
        padding: 6px 12px;
        border-radius: 20px;
        display: inline-block;
    }

    .status-bad {
        color: #dc2626 !important;
        background: #fee2e2;
        padding: 6px 12px;
        border-radius: 20px;
        display: inline-block;
    }

    .password-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .profile-btn {
        background: #1d6fd6;
        color: white;
        padding: 8px 14px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
    }

        .profile-btn:hover {
            background: #155ab0;
            color: white;
        }
</style>