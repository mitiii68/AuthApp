@{
    ViewData["Title"] = "Забыли пароль?";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title mb-1">Забыли пароль?</h4>
                <p class="text-muted small mb-4">Введите email — мы отправим код для сброса пароля.</p>

                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="email"
                               class="form-control" placeholder="you@example.com"
                               value="@TempData["ResetEmail"]" required autofocus />
                        <span class="text-danger small">@Html.ValidationMessage("email")</span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Отправить код</button>
                </form>

                <div class="text-center mt-3">
                    <a asp-action="Login" class="text-muted small">← Вернуться к входу</a>
                </div>
            </div>
        </div>
    </div>
</div>
