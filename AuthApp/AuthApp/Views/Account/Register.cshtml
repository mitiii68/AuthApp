@model AuthApp.Models.RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-page {
        min-height: calc(100vh - 58px - 53px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        background: var(--bg);
    }

    .auth-card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 40px 40px 36px;
        width: 100%;
        max-width: 420px;
        box-shadow: var(--shadow-md);
        animation: fadeUp 0.3s ease;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .auth-icon {
        width: 48px;
        height: 48px;
        background: var(--blue-light);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

        .auth-icon svg {
            width: 24px;
            height: 24px;
            fill: var(--blue);
        }

    .auth-title {
        font-size: 22px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 4px;
    }

    .auth-sub {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 28px;
    }

    .form-field {
        margin-bottom: 16px;
    }

        .form-field label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 6px;
        }

        .form-field input {
            width: 100%;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            background: var(--white);
            color: var(--text);
            font-family: 'Golos Text', sans-serif;
            font-size: 14px;
            transition: border-color 0.15s, box-shadow 0.15s;
            outline: none;
            box-sizing: border-box;
        }

            .form-field input:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(26, 111, 212, 0.12);
            }

            .form-field input::placeholder {
                color: #c0c7d0;
            }

    .field-error {
        font-size: 12px;
        color: #dc2626;
        margin-top: 4px;
    }

    .input-error {
        border-color: #dc2626 !important;
    }

    .btn-submit {
        width: 100%;
        padding: 11px;
        background: var(--blue);
        color: white;
        border: none;
        border-radius: var(--radius-sm);
        font-family: 'Golos Text', sans-serif;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
        margin-top: 4px;
    }

        .btn-submit:hover {
            background: var(--blue-dark);
        }

        .btn-submit:active {
            transform: scale(0.99);
        }

    .btn-cancel {
        width: 100%;
        padding: 10px;
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-family: 'Golos Text', sans-serif;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.15s;
        margin-top: 10px;
    }

        .btn-cancel:hover {
            background: var(--bg);
            color: var(--text);
        }

    .auth-footer {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
        color: var(--text-muted);
    }

        .auth-footer a {
            color: var(--blue);
            text-decoration: none;
            font-weight: 500;
        }

            .auth-footer a:hover {
                text-decoration: underline;
            }

    .divider {
        border: none;
        border-top: 1px solid var(--border);
        margin: 20px 0;
    }

    .validation-summary {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: var(--radius-sm);
        padding: 10px 14px;
        margin-bottom: 20px;
        font-size: 13px;
        color: #dc2626;
    }
</style>

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-icon">
            <svg viewBox="0 0 24 24">
                <path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
        </div>

        <div class="auth-title">Создать аккаунт</div>
        <div class="auth-sub">Заполните данные для регистрации</div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary" asp-validation-summary="ModelOnly"></div>
        }

        <form asp-action="Register" method="post">
            <div class="form-field">
                <label asp-for="FullName">ФИО</label>
                <input asp-for="FullName"
                       placeholder="Иванов Иван Иванович"
                       class="@(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "input-error" : "")" />
                <div class="field-error">
                    <span asp-validation-for="FullName"></span>
                </div>
            </div>

            <div class="form-field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email"
                       type="email"
                       placeholder="ivan@example.com"
                       class="@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "input-error" : "")" />
                <div class="field-error">
                    <span asp-validation-for="Email"></span>
                </div>
            </div>

            <div class="form-field">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password"
                       type="password"
                       placeholder="Минимум 8 символов"
                       class="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "input-error" : "")" />
                <div class="field-error">
                    <span asp-validation-for="Password"></span>
                </div>
            </div>

            <div class="form-field">
                <label asp-for="ConfirmPassword">Повторите пароль</label>
                <input asp-for="ConfirmPassword"
                       type="password"
                       placeholder="Повторите пароль"
                       class="@(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "input-error" : "")" />
                <div class="field-error">
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>
            </div>

            <button type="submit" class="btn-submit">Зарегистрироваться</button>
            <a asp-controller="Account" asp-action="Login" class="btn-cancel" style="display:block; text-align:center; text-decoration:none;">
                Отмена
            </a>
        </form>

        <hr class="divider" />

        <div class="auth-footer">
            Уже есть аккаунт?
            <a asp-controller="Account" asp-action="Login">Войти</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}