@{
    ViewData["Title"] = "Введите код";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title mb-1">Введите код</h4>
                <p class="text-muted small mb-4">
                    Мы отправили 6-значный код на вашу почту. Код действителен <strong>15 минут</strong>.
                </p>

                <form asp-action="VerifyResetCode" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"
                         style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    @* *@
                    <input type="hidden" name="email" value="@(TempData["ResetEmail"] ?? TempData.Peek("ResetEmail"))" />

                    <div class="mb-3">
                        <label for="code" class="form-label">Код из письма</label>
                        <input type="text" id="code" name="code"
                               class="form-control form-control-lg text-center"
                               maxlength="6" placeholder="——————"
                               autocomplete="one-time-code" required autofocus
                               style="letter-spacing: 8px; font-size: 1.6rem;" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Проверить код</button>
                </form>

                <div class="text-center mt-3">
                    <a asp-action="ForgotPassword" class="text-muted small">Отправить код повторно</a>
                </div>
            </div>
        </div>
    </div>
</div>
