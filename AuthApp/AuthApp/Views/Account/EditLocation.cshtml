@model AuthApp.Models.User

@{
    ViewData["Title"] = "Местоположение";
    var lat = Model.Latitude ?? 49.9483;
    var lng = Model.Longitude ?? 82.6170;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .edit-page { max-width: 860px; margin: 36px auto; padding: 0 20px; }
    .edit-card {
        background: white;
        border: 1px solid #dfe3ea;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
    }
    .edit-header {
        padding: 22px 28px;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .edit-header h2 { margin: 0; font-size: 20px; font-weight: 700; color: #111827; }
    .edit-body { padding: 28px; }
    .section-label {
        font-size: 12px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .06em; color: #6b7280; margin: 0 0 14px;
    }
    .form-grid   { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    .form-group  { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-size: 13px; font-weight: 600; color: #374151; }
    .fc {
        height: 40px; padding: 0 12px;
        border: 1px solid #d1d5db; border-radius: 10px;
        font-size: 14px; color: #1f2937; background: #fff;
        outline: none; transition: border-color .15s;
        font-family: inherit; width: 100%; box-sizing: border-box;
    }
    .fc:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.1); }
    .fc:disabled { background: #f9fafb; color: #9ca3af; cursor: not-allowed; }
    hr.div { border: none; border-top: 1px solid #e5e7eb; margin: 24px 0; }
    #map { height: 280px; border-radius: 12px; border: 1px solid #d1d5db; margin-top: 16px; }
    .map-hint { font-size: 12px; color: #9ca3af; margin-top: 8px; }
    .btn-row { display: flex; gap: 10px; margin-top: 28px; flex-wrap: wrap; }
    .btn-save {
        height: 42px; padding: 0 28px; background: #1d6fd6; color: #fff;
        border: none; border-radius: 10px; font-size: 14px; font-weight: 600;
        cursor: pointer; transition: background .15s;
    }
    .btn-save:hover { background: #155ab0; }
    .btn-cancel {
        height: 42px; padding: 0 24px; background: #f3f4f6; color: #374151;
        border: 1px solid #d1d5db; border-radius: 10px; font-size: 14px; font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center;
    }
    .btn-cancel:hover { background: #e5e7eb; color: #374151; }
    .btn-clear {
        height: 42px; padding: 0 20px; background: #fee2e2; color: #b91c1c;
        border: none; border-radius: 10px; font-size: 14px; font-weight: 600;
        cursor: pointer; margin-left: auto;
    }
    .btn-clear:hover { background: #fecaca; }
</style>

<div class="edit-page">
    <div class="edit-card">
        <div class="edit-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1d6fd6"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
            <h2>Редактирование местоположения</h2>
        </div>

        <div class="edit-body">
            <form method="post" asp-action="EditLocation" asp-controller="Account">

                <p class="section-label">Административное деление (КАТО)</p>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Район / Г.А.</label>
                        <select id="selDistrict" name="district" class="fc">
                            <option value="">⏳ Загрузка...</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Сельский округ</label>
                        <select id="selRural" name="ruralDistrict" class="fc" disabled>
                            <option value="">— Выберите район —</option>
                        </select>
                    </div>
                </div>

                <hr class="div" />
                <p class="section-label">Адрес</p>

                <div class="form-grid" style="margin-bottom:16px;">
                    <div class="form-group">
                        <label>Населённый пункт</label>
                        <select id="selSettlement" name="settlement" class="fc" disabled>
                            <option value="">— Выберите округ —</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Улица</label>
                        <input class="fc" type="text" name="street"
                               value="@Model.Street" placeholder="Например: ул. Ленина" />
                    </div>
                </div>

                <div class="form-grid-3">
                    <div class="form-group">
                        <label>Дом</label>
                        <input class="fc" type="text" name="house"
                               value="@Model.House" placeholder="№ дома" />
                    </div>
                    <div class="form-group">
                        <label>Широта</label>
                        <input class="fc" type="text" id="latInput" name="latitude"
                               value="@(Model.Latitude.HasValue ? Model.Latitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) : "")"
                               placeholder="49.948300" />
                    </div>
                    <div class="form-group">
                        <label>Долгота</label>
                        <input class="fc" type="text" id="lngInput" name="longitude"
                               value="@(Model.Longitude.HasValue ? Model.Longitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) : "")"
                               placeholder="82.617000" />
                    </div>
                </div>

                <div id="map"></div>
                <p class="map-hint">📍 Кликните по карте или перетащите маркер чтобы указать точное местоположение</p>

                <div class="btn-row">
                    <button type="submit" class="btn-save">💾 Сохранить</button>
                    <a asp-controller="Account" asp-action="Profile" class="btn-cancel">Отмена</a>
                    <button type="button" class="btn-clear" onclick="clearAll()">🗑 Очистить</button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    
    const savedDistrict   = '@Html.Raw(Model.District?.Replace("'", "\\'") ?? "")';
    const savedRural      = '@Html.Raw(Model.RuralDistrict?.Replace("'", "\\'") ?? "")';
    const savedSettlement = '@Html.Raw(Model.Settlement?.Replace("'", "\\'") ?? "")';

    const selDistrict   = document.getElementById('selDistrict');
    const selRural      = document.getElementById('selRural');
    const selSettlement = document.getElementById('selSettlement');

    function resetSelect(sel, placeholder) {
        sel.innerHTML = `<option value="">${placeholder}</option>`;
        sel.disabled = true;
    }

    async function apiFetch(url) {
        const res = await fetch(url);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
    }

    
    async function loadDistricts() {
        try {
            const data = await apiFetch('/api/kato/districts');
            selDistrict.innerHTML = '<option value="">— Выберите район / Г.А. —</option>';
            data.forEach(item => {
                const opt = document.createElement('option');
                opt.value = item.name;          
                opt.dataset.code = item.code;   
                opt.textContent = item.name;
                if (item.name === savedDistrict) opt.selected = true;
                selDistrict.appendChild(opt);
            });
            selDistrict.disabled = false;

           
            const opt = selDistrict.options[selDistrict.selectedIndex];
            if (opt && opt.dataset.code) {
                await loadRural(opt.dataset.code);
            }
        } catch (e) {
            selDistrict.innerHTML = '<option value="">⚠️ Ошибка загрузки КАТО</option>';
            console.error('КАТО districts:', e);
        }
    }

    
    async function loadRural(districtCd) {
        resetSelect(selRural, '⏳ Загрузка...');
        resetSelect(selSettlement, '— Выберите округ —');

        try {
            const data = await apiFetch('/api/kato/rural/' + districtCd);

            if (data.length === 0) {
                
                selRural.innerHTML = '<option value="__none__">— Нет сельских округов —</option>';
                selRural.disabled = false;
                await loadSettlements(districtCd, '00');
            } else {
                selRural.innerHTML = '<option value="">— Выберите сельский округ —</option>';
                data.forEach(item => {
                    const opt = document.createElement('option');
                    opt.value = item.name;
                    opt.dataset.code = item.code;
                    opt.textContent = item.name;
                    if (item.name === savedRural) opt.selected = true;
                    selRural.appendChild(opt);
                });
                selRural.disabled = false;

                const opt = selRural.options[selRural.selectedIndex];
                if (opt && opt.dataset.code) {
                    await loadSettlements(districtCd, opt.dataset.code);
                }
            }
        } catch (e) {
            selRural.innerHTML = '<option value="">⚠️ Ошибка</option>';
            selRural.disabled = false;
            console.error('КАТО rural:', e);
        }
    }

    
    async function loadSettlements(districtCd, ruralCd) {
        resetSelect(selSettlement, '⏳ Загрузка...');

        try {
            const data = await apiFetch('/api/kato/settlements/' + districtCd + '/' + ruralCd);

            selSettlement.innerHTML = '<option value="">— Выберите населённый пункт —</option>';
            data.forEach(item => {
                const opt = document.createElement('option');
                opt.value = item.name;
                opt.textContent = item.name;
                if (item.name === savedSettlement) opt.selected = true;
                selSettlement.appendChild(opt);
            });
            selSettlement.disabled = false;
        } catch (e) {
            selSettlement.innerHTML = '<option value="">⚠️ Ошибка</option>';
            selSettlement.disabled = false;
            console.error('КАТО settlements:', e);
        }
    }

        selDistrict.addEventListener('change', function () {
        resetSelect(selRural, '— Выберите округ —');
        resetSelect(selSettlement, '— Выберите нас. пункт —');
        const opt = this.options[this.selectedIndex];
        if (opt && opt.dataset.code) {
            loadRural(opt.dataset.code);
            flyToDistrict(opt.value);
        }
    });


   
    selRural.addEventListener('change', function () {
        resetSelect(selSettlement, '— Выберите нас. пункт —');
        const distOpt = selDistrict.options[selDistrict.selectedIndex];
        if (!distOpt || !distOpt.dataset.code) return;
        const ruralOpt = this.options[this.selectedIndex];
        const ruralCd = (ruralOpt && ruralOpt.dataset.code) ? ruralOpt.dataset.code : '00';
        loadSettlements(distOpt.dataset.code, ruralCd);
    });

    
    function clearAll() {
        selDistrict.value = '';
        resetSelect(selRural, '— Выберите округ —');
        resetSelect(selSettlement, '— Выберите нас. пункт —');
        document.getElementById('latInput').value = '';
        document.getElementById('lngInput').value = '';
        marker.setLatLng([49.9483, 82.6170]);
        map.setView([49.9483, 82.6170], 13);
    }

    
    var initLat = @lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var initLng = @lng.ToString(System.Globalization.CultureInfo.InvariantCulture);

    var map = L.map('map').setView([initLat, initLng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    var marker = L.marker([initLat, initLng], { draggable: true }).addTo(map);

    function setCoords(lat, lng) {
        document.getElementById('latInput').value = lat.toFixed(6);
        document.getElementById('lngInput').value = lng.toFixed(6);
    }

    marker.on('dragend', function () {
        var p = marker.getLatLng();
        setCoords(p.lat, p.lng);
    });

    map.on('click', function (e) {
        marker.setLatLng(e.latlng);
        setCoords(e.latlng.lat, e.latlng.lng);
    });

        async function flyToDistrict(districtName) {
        try {
            const res = await fetch(
                `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(districtName + ', Восточно-Казахстанская область, Казахстан')}&format=json&limit=1`
            );
            const data = await res.json();
            if (data && data.length > 0) {
                const lt = parseFloat(data[0].lat);
                const ln = parseFloat(data[0].lon);
                map.flyTo([lt, ln], 10);
                marker.setLatLng([lt, ln]);
                setCoords(lt, ln);
            }
        } catch (e) {
            console.error('Геокодирование:', e);
        }
    }


   
    loadDistricts();
</script>
