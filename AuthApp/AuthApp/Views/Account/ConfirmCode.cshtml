@{
    ViewData["Title"] = "Подтверждение";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-page {
        min-height: calc(100vh - 58px - 53px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        background: var(--bg);
    }
    .auth-card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 40px 40px 36px;
        width: 100%;
        max-width: 400px;
        box-shadow: var(--shadow-md);
        animation: fadeUp 0.3s ease;
        text-align: center;
    }
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .confirm-icon {
        width: 64px;
        height: 64px;
        background: var(--blue-light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }
    .confirm-icon svg {
        width: 30px;
        height: 30px;
        fill: var(--blue);
    }
    .auth-title {
        font-size: 22px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 8px;
    }
    .auth-sub {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 28px;
        line-height: 1.5;
    }
    .auth-sub strong {
        color: var(--text);
        font-weight: 500;
    }
    .form-field {
        margin-bottom: 16px;
        text-align: left;
    }
    .form-field label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: var(--text);
        margin-bottom: 6px;
    }
    .form-field input {
        width: 100%;
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: var(--white);
        color: var(--text);
        font-family: 'Golos Text', sans-serif;
        font-size: 14px;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
    }
    .form-field input:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(26, 111, 212, 0.12);
    }
    .code-input {
        font-size: 22px !important;
        letter-spacing: 8px;
        text-align: center;
        font-weight: 600;
    }
    .error-box {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: var(--radius-sm);
        padding: 10px 14px;
        margin-bottom: 20px;
        font-size: 13px;
        color: #dc2626;
        text-align: left;
    }
    .btn-submit {
        width: 100%;
        padding: 11px;
        background: var(--blue);
        color: white;
        border: none;
        border-radius: var(--radius-sm);
        font-family: 'Golos Text', sans-serif;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
    }
    .btn-submit:hover { background: var(--blue-dark); }
    .btn-submit:active { transform: scale(0.99); }

    .hint {
        margin-top: 16px;
        font-size: 13px;
        color: var(--text-muted);
    }
</style>

<div class="auth-page">
    <div class="auth-card">

        <div class="confirm-icon">
            <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>

        <div class="auth-title">Подтвердите email</div>
        <div class="auth-sub">
            Мы отправили 6-значный код на<br>
            <strong>@TempData["Email"]</strong>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-box">
                @Html.ValidationSummary(false)
            </div>
        }

        <form method="post" asp-action="ConfirmCode">
            <input type="hidden" name="email" value="@TempData["Email"]" />

            <div class="form-field">
                <label>Код подтверждения</label>
                <input type="text" name="code" class="code-input" placeholder="000000"
                       maxlength="6" autocomplete="one-time-code" required />
            </div>

            <button type="submit" class="btn-submit">Подтвердить</button>
        </form>

        <div class="hint">Не получили код? Проверьте папку «Спам»</div>
    </div>
</div>
