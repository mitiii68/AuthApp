@model List<Tag>
@{
    ViewData["Title"] = "Теги";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<TagCategory>;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Теги</h1>
        <p class="page-subtitle">Управление тегами для маркировки документов</p>
    </div>
    <button class="btn btn-primary" onclick="toggleForm()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Добавить тег
    </button>
</div>

<div class="add-form-card" id="addForm" style="display:none">
    <div class="add-form-header">
        <span>Новый тег</span>
        <button class="btn-close-x" onclick="toggleForm()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="add-form-body">
        <form asp-action="Create" method="post">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Название тега</label>
                    <input type="text" name="name" placeholder="Например: Договор" required class="form-input" />
                </div>
                <div class="form-group">
                    <label class="form-label">Категория</label>
                    <select name="categoryIds" multiple class="form-control">
                        @foreach (var category in ViewBag.Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
            </div>
            <div class="form-footer">
                <button type="button" class="btn btn-ghost" onclick="toggleForm()">Отмена</button>
                <button type="submit" class="btn btn-primary">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Сохранить
                </button>
            </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span>Всего тегов: <strong>@Model.Count</strong></span>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
            </svg>
            <p>Тегов пока нет</p>
            <span>Нажмите «Добавить тег» чтобы создать первый</span>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:56px">#</th>
                    <th>Тег</th>
                    <th>Категории</th>
                    <th style="width:120px" class="td-right">Действие</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model)
                {
                    var catNames = string.Join(", ", tag.TagCategoryTags
                        .Select(tct => tct.TagCategory?.Name)
                        .Where(n => n != null));

                    <tr>
                        <td class="td-muted">@tag.Id</td>
                        <td>
                            <span class="badge bg-primary">@tag.Name</span>
                        </td>

                        <td>
                            @foreach (var item in tag.TagCategoryTags)
                            {
                                if (item.TagCategory != null)
                                {
                                    <span class="badge bg-success">@item.TagCategory.Name</span>
                                }
                            }
                        </td>

                       <td>
    <div class="d-flex align-items-center gap-3">
        <button type="button"
                class="btn btn-sm btn-warning"
                onclick="openEditModal(@tag.Id, '@tag.Name')">
            ✎
        </button>

        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@tag.Id" />
            <button type="submit" class="btn btn-sm btn-danger">
                Удалить
            </button>
        </form>
    </div>
</td>

                        
                        
                        
                    </tr>
                }
            </tbody>
        </table>

        <div id="editModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:999;">
            <div style="background:white; width:450px; margin:100px auto; padding:20px; border-radius:12px;">
                <h4>Редактировать тег</h4>

                <form asp-action="Edit" method="post">
                    <input type="hidden" id="editTagId" name="id" />

                    <div>
                        <label>Название тега</label>
                        <input type="text" id="editTagName" name="name" class="form-control" />
                    </div>

                    <div style="margin-top:15px;">
                        <label>Категории</label>

                        @foreach (var category in ViewBag.Categories)
                        {
                            <label style="display:block;">
                                <input type="checkbox"
                                       class="edit-category-checkbox"
                                       name="categoryIds"
                                       value="@category.Id" />
                                @category.Name
                            </label>
                        }
                    </div>

                    <div style="margin-top:15px;">
                        <button type="submit" class="btn btn-success">Сохранить</button>
                        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Отмена</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

<script>
function toggleForm() {
    const f = document.getElementById('addForm');
    f.style.display = f.style.display === 'none' ? 'block' : 'none';
    if (f.style.display === 'block') f.querySelector('input').focus();
}
</script>

<script>
    function openEditModal(id, name) {
        document.getElementById('editTagId').value = id;
        document.getElementById('editTagName').value = name;

        document.querySelectorAll('.edit-category-checkbox').forEach(x => {
            x.checked = false;
        });

        document.getElementById('editModal').style.display = 'block';
    }

    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
    }
</script>
