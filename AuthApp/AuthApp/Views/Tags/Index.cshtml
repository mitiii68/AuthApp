@model List<Tag>
@{
    ViewData["Title"] = "Теги";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<TagCategory>;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@@400;500;600;700;800&display=swap');

    :root {
        --accent:       #3b5bdb;
        --accent-light: #e7ecfd;
        --accent-hover: #2f4ac7;
        --surface:      #ffffff;
        --surface-2:    #f8f9fc;
        --border:       #e3e8f0;
        --text:         #1a1d2e;
        --text-sub:     #6b7280;
        --danger:       #e03131;
        --danger-light: #fff0f0;
        --warning:      #e67700;
        --warning-light:#fff8ec;
        --success:      #2f9e44;
        --success-light:#ebfbee;
        --shadow-sm:    0 1px 4px rgba(59,91,219,.08);
        --shadow-md:    0 4px 24px rgba(59,91,219,.13);
        --radius:       12px;
        --font:         'Nunito', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font); color: var(--text); background: var(--surface-2); }

    .docs-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        margin-top: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .docs-header h1 {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -.4px;
        line-height: 1.2;
    }
    .docs-header p {
        font-size: 14px;
        color: var(--text-sub);
        margin-top: 3px;
        font-weight: 500;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 8px;
        font-family: var(--font);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: background .15s, box-shadow .15s, transform .1s;
        white-space: nowrap;
    }
    .btn:active { transform: scale(.98); }
    .btn-primary  { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(59,91,219,.25); }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-ghost    { background: var(--surface); color: var(--text); border: 1.5px solid var(--border); }
    .btn-ghost:hover { background: var(--surface-2); }
    .btn-sm { padding: 6px 12px; font-size: 13px; }

    .add-form-card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        margin-bottom: 20px;
        overflow: hidden;
    }
    .add-form-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1.5px solid var(--border);
        font-size: 14px;
        font-weight: 700;
        background: var(--surface-2);
    }
    .btn-close-x {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 6px;
        border: none;
        background: transparent;
        color: var(--text-sub);
        cursor: pointer;
        transition: background .12s, color .12s;
    }
    .btn-close-x:hover { background: var(--danger-light); color: var(--danger); }

    .add-form-body { padding: 20px; }
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: start;
    }
    @@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }

    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-label { font-size: 12.5px; font-weight: 700; color: var(--text-sub); text-transform: uppercase; letter-spacing: .05em; }
    .form-input, .form-select {
        padding: 9px 13px;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        font-family: var(--font);
        font-size: 14px;
        font-weight: 500;
        color: var(--text);
        background: var(--surface);
        transition: border-color .15s, box-shadow .15s;
        outline: none;
        width: 100%;
    }
    .form-input:focus, .form-select:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-light);
    }
    .form-select { min-height: 90px; }

    .cat-check-list { display: flex; flex-direction: column; gap: 6px; }
    .cat-check-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 11px;
        border-radius: 7px;
        border: 1.5px solid var(--border);
        background: var(--surface-2);
        cursor: pointer;
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text);
        transition: border-color .12s, background .12s;
        user-select: none;
    }
    .cat-check-item:hover { border-color: var(--accent); background: var(--accent-light); color: var(--accent); }
    .cat-check-item input[type="checkbox"] { accent-color: var(--accent); width: 15px; height: 15px; cursor: pointer; }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 18px;
        padding-top: 16px;
        border-top: 1.5px solid var(--border);
        grid-column: 1 / -1;
    }

    .card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }
    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1.5px solid var(--border);
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text-sub);
        background: var(--surface-2);
    }
    .card-header strong { color: var(--text); font-weight: 800; }

    .empty-state {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 64px 20px;
        color: var(--text-sub); gap: 12px; text-align: center;
    }
    .empty-state svg { opacity: .3; }
    .empty-state p { font-size: 16px; font-weight: 700; color: var(--text); }
    .empty-state span { font-size: 14px; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .data-table thead th {
        padding: 11px 16px;
        background: var(--surface-2);
        font-size: 11.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--text-sub);
        border-bottom: 1.5px solid var(--border);
        text-align: left;
        white-space: nowrap;
    }
    .data-table thead th.th-right { text-align: right; }
    .data-table tbody tr { border-bottom: 1px solid var(--border); transition: background .12s; }
    .data-table tbody tr:last-child { border-bottom: none; }
    .data-table tbody tr:hover { background: #f4f6ff; }
    .data-table td { padding: 12px 16px; vertical-align: middle; }
    .td-muted { color: var(--text-sub); font-size: 13px; font-weight: 600; }
    .td-right { text-align: right; }

    .tag-list { display: flex; flex-wrap: wrap; gap: 5px; }
    .badge-tag {
        display: inline-flex; align-items: center;
        padding: 4px 11px; border-radius: 20px;
        font-size: 12px; font-weight: 700;
        background: var(--accent-light);
        color: var(--accent);
        border: 1.5px solid rgba(59,91,219,.18);
    }
    .badge-cat {
        display: inline-flex; align-items: center;
        padding: 4px 11px; border-radius: 20px;
        font-size: 12px; font-weight: 700;
        background: var(--success-light);
        color: var(--success);
        border: 1.5px solid rgba(47,158,68,.2);
    }

    .actions { display: flex; gap: 6px; justify-content: flex-end; align-items: center; }
    .btn-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 34px; height: 34px; border-radius: 8px;
        border: 1.5px solid var(--border); background: var(--surface);
        color: var(--text-sub); cursor: pointer;
        transition: background .12s, border-color .12s, color .12s;
        text-decoration: none; flex-shrink: 0;
    }
    .btn-icon:hover { background: var(--warning-light); border-color: var(--warning); color: var(--warning); }
    .btn-icon.danger:hover { background: var(--danger-light); border-color: var(--danger); color: var(--danger); }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,20,40,.55);
        z-index: 999;
        align-items: center;
        justify-content: center;
    }
    .modal-overlay.open {
        display: flex;
    }
    .modal {
        background: var(--surface);
        width: 460px;
        max-width: calc(100vw - 32px);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        border: 1.5px solid var(--border);
        overflow: hidden;
        animation: modalIn .18s ease;
    }
    @@keyframes modalIn {
        from { opacity: 0; transform: translateY(-12px) scale(.97); }
        to   { opacity: 1; transform: none; }
    }
    .modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1.5px solid var(--border);
        font-size: 15px; font-weight: 800;
        background: var(--surface-2);
    }
    .modal-body { padding: 20px; display: flex; flex-direction: column; gap: 16px; }
    .modal-footer {
        display: flex; justify-content: flex-end; gap: 10px;
        padding: 16px 20px;
        border-top: 1.5px solid var(--border);
        background: var(--surface-2);
    }

    /* Fix: make custom modal visible despite Bootstrap's .modal rules */
    .modal-overlay.open .modal {
        display: block !important;
        position: relative; 
        z-index: 1000;      
    }

    /* ─── Панель поиска тегов ─── */
    .search-panel {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        padding: 14px 18px;
        margin-bottom: 18px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: flex-end;
    }
    .search-field { flex: 1 1 220px; }
    .filter-field { flex: 0 1 190px; }
    .sort-field   { flex: 0 1 170px; }
    .search-label {
        display: block;
        font-size: 11.5px;
        font-weight: 700;
        color: var(--text-sub);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 5px;
    }
    .search-input-wrap { position: relative; }
    .search-input-wrap svg {
        position: absolute; left: 10px; top: 50%;
        transform: translateY(-50%); color: var(--text-sub); pointer-events: none;
    }
    .search-input {
        width: 100%; padding: 8px 12px 8px 34px;
        border: 1.5px solid var(--border); border-radius: 8px;
        font-family: var(--font); font-size: 14px; font-weight: 500;
        color: var(--text); background: var(--surface-2); outline: none;
        transition: border-color .15s, box-shadow .15s, background .15s;
    }
    .search-input:focus {
        border-color: var(--accent); background: var(--surface);
        box-shadow: 0 0 0 3px var(--accent-light);
    }
    .filter-select {
        width: 100%; padding: 8px 12px;
        border: 1.5px solid var(--border); border-radius: 8px;
        font-family: var(--font); font-size: 14px; font-weight: 500;
        color: var(--text); background: var(--surface-2); outline: none;
        cursor: pointer; appearance: none;
        transition: border-color .15s, box-shadow .15s;
        background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 24 24' fill='none' stroke='%236b7280' stroke-width='2.5' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='6 9 12 15 18 9'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 10px center;
        padding-right: 32px;
    }
    .filter-select:focus {
        border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-light);
    }
    .no-results-row td {
        text-align: center; padding: 40px 20px;
        color: var(--text-sub); font-size: 14px; font-weight: 600;
    }

</style>

<div class="docs-header">
    <div>
        <h1>Теги</h1>
        <p>Управление тегами для маркировки документов</p>
    </div>
    <button class="btn btn-primary" onclick="toggleForm()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Добавить тег
    </button>
</div>

<div class="add-form-card" id="addForm" style="display:none">
    <div class="add-form-header">
        <span>Новый тег</span>
        <button class="btn-close-x" onclick="toggleForm()" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="add-form-body">
        <form asp-action="Create" method="post">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Название тега</label>
                    <input type="text" name="name" placeholder="Например: Договор" required class="form-input" />
                </div>
                <div class="form-group">
                    <label class="form-label">Категория</label>
                    <div class="cat-check-list">
                        @foreach (var cat in categories ?? new List<TagCategory>())
                        {
                            <label class="cat-check-item">
                                <input type="checkbox" name="categoryIds" value="@cat.Id" />
                                @cat.Name
                            </label>
                        }
                    </div>
                </div>
                <div class="form-footer">
                    <button type="button" class="btn btn-ghost" onclick="toggleForm()">Отмена</button>
                    <button type="submit" class="btn btn-primary">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Сохранить
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="search-panel">
    <div class="search-field">
        <label class="search-label" for="tagSearch">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:2px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Поиск
        </label>
        <div class="search-input-wrap">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="tagSearch" type="text" class="search-input" placeholder="Название тега..." autocomplete="off" />
        </div>
    </div>
    <div class="filter-field">
        <label class="search-label" for="catFilter">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:2px"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            Категория
        </label>
        <select id="catFilter" class="filter-select">
            <option value="">Все категории</option>
            @foreach (var cat in categories ?? new List<TagCategory>())
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>
    <div class="sort-field">
        <label class="search-label" for="tagSort">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:2px"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            Сортировка
        </label>
        <select id="tagSort" class="filter-select">
            <option value="az">По имени A–Z</option>
            <option value="za">По имени Z–A</option>
            <option value="id_asc">Сначала старые</option>
            <option value="id_desc">Сначала новые</option>
        </select>
    </div>
    <div style="display:flex;gap:8px;align-items:flex-end;flex-shrink:0">
        <button type="button" id="resetFilters" class="btn btn-ghost btn-sm" style="display:none">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Сбросить
        </button>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span>Показано: <strong id="tagCount">@Model.Count</strong> из @Model.Count</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
            </svg>
            <p>Тегов пока нет</p>
            <span>Нажмите «Добавить тег» чтобы создать первый</span>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:56px">#</th>
                    <th>Тег</th>
                    <th>Категории</th>
                    <th style="width:110px" class="th-right">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model)
                {
                    var tagCatIds = string.Join(",", tag.TagCategoryTags.Select(t => t.TagCategoryId));
                    <tr data-name="@tag.Name.ToLower()" data-cats="@tagCatIds" data-id="@tag.Id">
                        <td class="td-muted">@tag.Id</td>
                        <td>
                            <span class="badge-tag">@tag.Name</span>
                        </td>
                        <td>
                            <div class="tag-list">
                                @foreach (var item in tag.TagCategoryTags)
                                {
                                    if (item.TagCategory != null)
                                    {
                                        <span class="badge-cat">@item.TagCategory.Name</span>
                                    }
                                }
                            </div>
                        </td>
                        <td class="td-right">
                            <div class="actions">
                                <button type="button" class="btn-icon"
                                        data-id="@tag.Id"
                                        data-name="@tag.Name"
                                        data-categories='@Json.Serialize(tag.TagCategoryTags.Select(t => t.TagCategoryId).ToList())'
                                        onclick="openEditModal(this)"
                                        title="Редактировать">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </button>
                                <form asp-action="Delete" method="post" style="display:inline"
                                      onsubmit="return confirm('Удалить тег «@tag.Name»?')">
                                    <input type="hidden" name="id" value="@tag.Id" />
                                    <button type="submit" class="btn-icon danger" title="Удалить">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                                            <path d="M10 11v6M14 11v6M9 6V4h6v2"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div id="editModal" class="modal-overlay">
    <div class="modal">
        <div class="modal-header">
            <span>Редактировать тег</span>
            <button class="btn-close-x" type="button" onclick="closeEditModal()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <form asp-action="Edit" method="post">
            <input type="hidden" id="editTagId" name="id" />
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Название тега</label>
                    <input type="text" id="editTagName" name="name" class="form-input" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Категории</label>
                    <div class="cat-check-list">
                        @foreach (var cat in categories ?? new List<TagCategory>())
                        {
                            <label class="cat-check-item">
                                <input type="checkbox"
                                       class="edit-category-checkbox"
                                       name="categoryIds"
                                       value="@cat.Id" />
                                @cat.Name
                            </label>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeEditModal()">Отмена</button>
                <button type="submit" class="btn btn-primary">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Сохранить
                </button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('editModal');
    const editTagId = document.getElementById('editTagId');
    const editTagName = document.getElementById('editTagName');
    const editCategoryCheckboxes = Array.from(document.querySelectorAll('.edit-category-checkbox'));

    document.addEventListener('click', function(e) {
        
        const btn = e.target.closest('.btn-icon');
        if (btn && btn.getAttribute('data-id')) {
            openEditModal(btn);
            return;
        }

        if (e.target.closest('.btn-close-x') || e.target === modal) {
            closeEditModal();
        }
    });

    // expose functions for inline handlers and other scripts
    window.openEditModal = function(source) {
        const btn = source && source.getAttribute ? source : null;
        if (!btn) return;

        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const catRaw = btn.getAttribute('data-categories');

        if (editTagId) editTagId.value = id || '';
        if (editTagName) editTagName.value = name || '';

        
        let categoryIds = [];
        try {
            categoryIds = JSON.parse(catRaw || "[]");
        } catch (err) {
            categoryIds = [];
        }
        const categorySet = new Set((categoryIds || []).map(Number));
        editCategoryCheckboxes.forEach(cb => {
            cb.checked = categorySet.has(Number(cb.value));
        });

        
        modal.classList.add('open');
        if (editTagName) editTagName.focus();
    };

    window.closeEditModal = function() {
        if (modal) modal.classList.remove('open');
    };
});


function toggleForm() {
    const f = document.getElementById('addForm');
    if (!f) return;
    f.style.display = f.style.display === 'none' ? 'block' : 'none';
    if (f.style.display === 'block') f.querySelector('input[type="text"]').focus();
    }

// ─── Живой поиск и сортировка тегов ───
(function() {
    const searchInput  = document.getElementById('tagSearch');
    const catFilter    = document.getElementById('catFilter');
    const sortSelect   = document.getElementById('tagSort');
    const resetBtn     = document.getElementById('resetFilters');
    const countEl      = document.getElementById('tagCount');
    const tbody        = document.querySelector('.data-table tbody');

    if (!tbody || !searchInput) return;

    function getRows() {
        return Array.from(tbody.querySelectorAll('tr[data-name]'));
    }

    function applyFilters() {
        const search = searchInput.value.trim().toLowerCase();
        const cat    = catFilter ? catFilter.value : '';
        const sort   = sortSelect ? sortSelect.value : 'az';

        let rows = getRows();

        // Фильтрация
        rows.forEach(row => {
            const name    = row.getAttribute('data-name') || '';
            const cats    = row.getAttribute('data-cats') || '';
            const nameOk  = !search || name.includes(search);
            const catOk   = !cat    || cats.split(',').includes(cat);
            row.style.display = (nameOk && catOk) ? '' : 'none';
        });

        // Сортировка видимых строк
        const visible = rows.filter(r => r.style.display !== 'none');
        visible.sort((a, b) => {
            const nameA = a.getAttribute('data-name') || '';
            const nameB = b.getAttribute('data-name') || '';
            const idA   = parseInt(a.getAttribute('data-id') || '0');
            const idB   = parseInt(b.getAttribute('data-id') || '0');
            switch (sort) {
                case 'za':       return nameB.localeCompare(nameA, 'ru');
                case 'id_asc':   return idA - idB;
                case 'id_desc':  return idB - idA;
                default:         return nameA.localeCompare(nameB, 'ru'); // az
            }
        });
        visible.forEach(row => tbody.appendChild(row));

        // Счётчик
        if (countEl) countEl.textContent = visible.length;

        // Строка «ничего не найдено»
        let noRow = tbody.querySelector('.no-results-row');
        if (visible.length === 0) {
            if (!noRow) {
                noRow = document.createElement('tr');
                noRow.className = 'no-results-row';
                const cols = tbody.closest('table').querySelectorAll('thead th').length;
                noRow.innerHTML = `<td colspan="${cols}">Теги не найдены — попробуйте изменить запрос</td>`;
                tbody.appendChild(noRow);
            }
        } else {
            if (noRow) noRow.remove();
        }

        // Кнопка «Сбросить»
        if (resetBtn) {
            resetBtn.style.display = (search || cat) ? 'inline-flex' : 'none';
        }
    }

    searchInput.addEventListener('input', applyFilters);
    if (catFilter)  catFilter.addEventListener('change', applyFilters);
    if (sortSelect) sortSelect.addEventListener('change', applyFilters);

    if (resetBtn) {
        resetBtn.addEventListener('click', function() {
            searchInput.value = '';
            if (catFilter)  catFilter.value = '';
            applyFilters();
        });
    }

    // Начальная сортировка A–Z при загрузке
    applyFilters();
})();

</script>