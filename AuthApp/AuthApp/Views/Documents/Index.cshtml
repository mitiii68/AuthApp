@model List<FileDocuments>
@{
    ViewData["Title"] = "Документы";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tags = ViewBag.Tags as List<Tag>;
    var selectedTagId = ViewBag.SelectedTagId as int?;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Nunito...');

    :root {
        --accent:       #3b5bdb;
        --accent-light: #e7ecfd;
        --accent-hover: #2f4ac7;
        --surface:      #ffffff;
        --surface-2:    #f8f9fc;
        --border:       #e3e8f0;
        --text:         #1a1d2e;
        --text-sub:     #6b7280;
        --danger:       #e03131;
        --danger-light: #fff0f0;
        --shadow-sm:    0 1px 4px rgba(59,91,219,.08);
        --shadow-md:    0 4px 20px rgba(59,91,219,.10);
        --radius:       12px;
        --font:         'Nunito', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body { font-family: var(--font); color: var(--text); background: var(--surface-2); }

    
    .docs-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .docs-header h1 {
        font-size: 26px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -.4px;
        line-height: 1.2;
    }
    .docs-header p {
        font-size: 14px;
        color: var(--text-sub);
        margin-top: 3px;
        font-weight: 500;
    }

    
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 8px;
        font-family: var(--font);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: background .15s, box-shadow .15s, transform .1s;
    }
    .btn:active { transform: scale(.98); }
    .btn-primary {
        background: var(--accent);
        color: #fff;
        box-shadow: 0 2px 8px rgba(59,91,219,.25);
    }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-ghost {
        background: var(--surface);
        color: var(--text);
        border: 1.5px solid var(--border);
    }
    .btn-ghost:hover { background: var(--surface-2); }

    
    .filter-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        position: relative;
    }
    .filter-label {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-sub);
        text-transform: uppercase;
        letter-spacing: .06em;
    }
    .tag-dropdown-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: var(--surface);
        cursor: pointer;
        font-family: var(--font);
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text);
        transition: border-color .15s, box-shadow .15s;
        box-shadow: var(--shadow-sm);
    }
    .tag-dropdown-btn:hover { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-light); }
    .tag-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        left: 90px;
        z-index: 300;
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        min-width: 270px;
        max-width: 360px;
        padding: 12px;
    }
    .tag-dropdown-title {
        font-size: 11px;
        color: var(--text-sub);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        padding: 0 4px 10px;
    }
    .chip-list { display: flex; flex-wrap: wrap; gap: 6px; max-height: 280px; overflow-y: auto; padding: 2px 2px 4px; }
    .chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12.5px;
        font-weight: 600;
        background: var(--surface-2);
        border: 1.5px solid var(--border);
        color: var(--text);
        text-decoration: none;
        transition: background .12s, border-color .12s, color .12s;
        cursor: pointer;
    }
    .chip:hover { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }
    .chip.active { background: var(--accent); border-color: var(--accent); color: #fff; }
    .chip-sub { font-size: 11px; font-weight: 500; opacity: .75; }

   
    .card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }
    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1.5px solid var(--border);
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text-sub);
        background: var(--surface-2);
    }
    .card-header strong { color: var(--text); font-weight: 800; }

   
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 64px 20px;
        color: var(--text-sub);
        gap: 12px;
        text-align: center;
    }
    .empty-state svg { opacity: .35; }
    .empty-state p { font-size: 16px; font-weight: 700; color: var(--text); }
    .empty-state span { font-size: 14px; }

  
    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }
    .data-table thead th {
        padding: 11px 16px;
        background: var(--surface-2);
        font-size: 11.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--text-sub);
        border-bottom: 1.5px solid var(--border);
        text-align: left;
        white-space: nowrap;
    }
    .data-table thead th.th-right { text-align: right; }
    .data-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background .12s;
    }
    .data-table tbody tr:last-child { border-bottom: none; }
    .data-table tbody tr:hover { background: #f4f6ff; }
    .data-table td {
        padding: 13px 16px;
        vertical-align: middle;
    }
    .td-right { text-align: right; }


    .file-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        font-size: 9px;
        font-weight: 800;
        letter-spacing: .04em;
        color: #fff;
        flex-shrink: 0;
    }
    .fi-pdf   { background: #e03131; }
    .fi-doc, .fi-docx { background: #1971c2; }
    .fi-xls, .fi-xlsx { background: #2f9e44; }
    .fi-zip, .fi-rar, .fi-7z { background: #e67700; }
    .fi-default { background: #868e96; }

    
    .file-name {
        font-weight: 700;
        font-size: 14px;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 320px;
    }


    .tag-list { display: flex; flex-wrap: wrap; gap: 5px; }
    .badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 9px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 700;
        background: var(--accent-light);
        color: var(--accent);
        border: 1.5px solid rgba(59,91,219,.18);
    }

    
    .date-main { display: block; font-size: 13.5px; font-weight: 600; color: var(--text); }
    .date-sub  { display: block; font-size: 12px; color: var(--text-sub); font-weight: 500; margin-top: 1px; }

    
    .actions { display: flex; gap: 6px; justify-content: flex-end; align-items: center; }
    .btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: var(--surface);
        color: var(--text-sub);
        cursor: pointer;
        transition: background .12s, border-color .12s, color .12s;
        text-decoration: none;
        flex-shrink: 0;
    }
    .btn-icon:hover { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }
    .btn-icon.danger:hover { background: var(--danger-light); border-color: var(--danger); color: var(--danger); }
</style>


<div class="docs-header">
    <div>
        <h1>Документы</h1>
        <p>Хранилище файлов и документов</p>
    </div>
    <a asp-action="Upload" class="btn btn-primary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
            <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/>
        </svg>
        Загрузить файл
    </a>
</div>


<div class="filter-bar">
    <span class="filter-label">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
        </svg>
        Тег:
    </span>

    <button type="button" id="tagDropdownBtn" class="tag-dropdown-btn" onclick="toggleTagDropdown()">
        @if (selectedTagId == null)
        {
            <span>Все теги</span>
        }
        else
        {
            var selTag = tags?.FirstOrDefault(x => x.Id == selectedTagId);
            var selCatName = selTag?.TagCategoryTags?.FirstOrDefault()?.TagCategory?.Name;
            <span>@selTag?.Name</span>
            @if (!string.IsNullOrEmpty(selCatName))
            {
                <span style="color:var(--text-sub); font-weight:500">@selCatName</span>
            }
        }
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="6 9 12 15 18 9"/>
        </svg>
    </button>

    <div id="tagDropdown" class="tag-dropdown">
        <div class="tag-dropdown-title">Выберите тег</div>
        <div class="chip-list">
            <a asp-action="Index" onclick="closeTagDropdown()" class="chip @(selectedTagId == null ? "active" : "")">Все</a>
            @foreach (var tag in tags ?? new List<Tag>())
            {
                var catName = tag.TagCategoryTags?.FirstOrDefault()?.TagCategory?.Name;
                <a asp-action="Index" asp-route-tagId="@tag.Id" onclick="closeTagDropdown()"
                   class="chip @(selectedTagId == tag.Id ? "active" : "")">
                    @tag.Name
                    @if (!string.IsNullOrEmpty(catName))
                    {
                        <span class="chip-sub">@catName</span>
                    }
                </a>
            }
        </div>
    </div>
</div>

<script>
    function toggleTagDropdown() {
        var dd = document.getElementById('tagDropdown');
        dd.style.display = dd.style.display === 'none' || dd.style.display === '' ? 'block' : 'none';
    }
    function closeTagDropdown() {
        document.getElementById('tagDropdown').style.display = 'none';
    }
    document.addEventListener('click', function(e) {
        var btn = document.getElementById('tagDropdownBtn');
        var dd  = document.getElementById('tagDropdown');
        if (!btn.contains(e.target) && !dd.contains(e.target)) dd.style.display = 'none';
    });
</script>


<div class="card">
    <div class="card-header">
        <span>
            Найдено: <strong>@Model.Count</strong>
            @if (selectedTagId.HasValue)
            {
                var t = tags?.FirstOrDefault(x => x.Id == selectedTagId);
                <span style="color:var(--accent); font-weight:600"> — тег «@t?.Name»</span>
            }
        </span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            <p>Документов не найдено</p>
            <span>
                @if (selectedTagId.HasValue) { <text>Попробуйте снять фильтр или </text> }
                <a asp-action="Upload" style="color:var(--accent); font-weight:700;">загрузите первый документ</a>
            </span>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:56px"></th>
                    <th>Файл</th>
                    <th>Теги</th>
                    <th style="width:130px">Дата загрузки</th>
                    <th style="width:100px" class="th-right">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model)
                {
                    var ext = doc.Extension?.TrimStart('.').ToLower() ?? "";
                    var iconClass = ext switch {
                        "pdf"  => "fi-pdf",
                        "doc"  => "fi-doc",
                        "docx" => "fi-docx",
                        "xls"  => "fi-xls",
                        "xlsx" => "fi-xlsx",
                        "zip"  => "fi-zip",
                        "rar"  => "fi-rar",
                        "7z"   => "fi-7z",
                        _      => "fi-default"
                    };
                    <tr>
                        <td>
                            <span class="file-icon @iconClass">@ext.ToUpper()</span>
                        </td>
                        <td>
                            <span class="file-name">@doc.FileName</span>
                        </td>
                        <td>
                            <div class="tag-list">
                                @foreach (var ft in doc.FileTags ?? new List<FileTag>())
                                {
                                    <span class="badge">@ft.Tag?.Name</span>
                                }
                            </div>
                        </td>
                        <td>
                            <span class="date-main">@doc.UploadDate.ToString("dd.MM.yyyy")</span>
                            <span class="date-sub">@doc.UploadDate.ToString("HH:mm")</span>
                        </td>
                        <td class="td-right">
                            <div class="actions">
                                <a href="@doc.FilePath" download class="btn-icon" title="Скачать">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                                        <polyline points="7 10 12 15 17 10"/>
                                        <line x1="12" y1="15" x2="12" y2="3"/>
                                    </svg>
                                </a>
                                <form asp-action="Delete" method="post" style="display:inline"
                                      onsubmit="return confirm('Удалить файл «@doc.FileName»? Это действие необратимо.')">
                                    <input type="hidden" name="id" value="@doc.Id" />
                                    <button type="submit" class="btn-icon danger" title="Удалить">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                                            <path d="M10 11v6M14 11v6M9 6V4h6v2"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
