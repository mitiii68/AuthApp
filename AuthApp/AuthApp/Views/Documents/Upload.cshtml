@{
    ViewData["Title"] = "Загрузка файла";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tags = ViewBag.Tags as List<Tag>;
    var categories = ViewBag.Categories as List<TagCategory>;

    var grouped = tags?
        .GroupBy(t => t.TagCategoryTags?.FirstOrDefault()?.TagCategory?.Name ?? "Без категории")
        .ToDictionary(g => g.Key, g => g.ToList())
        ?? new Dictionary<string, List<Tag>>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Загрузка файла</h1>
        <p class="page-subtitle">Добавьте документ в хранилище</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Назад
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        @ViewBag.Error
    </div>
}

<form asp-action="Upload" method="post" enctype="multipart/form-data">
    <div class="two-col">
        <!-- Файл -->
        <div class="card">
            <div class="card-header"><strong>Файл</strong></div>
            <div class="drop-zone" id="dropZone">
                <input type="file" name="file" id="fileInput" required
                       accept=".doc,.docx,.xls,.xlsx,.pdf,.zip,.rar,.7z"
                       onchange="onFile(this)" />
                <div class="drop-icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
                        <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/>
                    </svg>
                </div>
                <div class="drop-text">Нажмите или перетащите файл</div>
                <div class="drop-hint">DOC, DOCX, XLS, XLSX, PDF, ZIP, RAR, 7Z</div>
                <div class="file-chosen" id="fileChosen">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <span id="chosenName"></span>
                </div>
            </div>
        </div>

        <!-- Теги -->
        <div class="card">
            <div class="card-header">
                <strong>Теги</strong>
                <span id="countLabel" style="color:var(--text-sub); font-size:13px">Выбрано: 0</span>
            </div>

            <!-- Фильтр по категориям -->
            <div style="padding:10px 16px; border-bottom:1px solid var(--border,#e5e7eb);">
                <div style="font-size:12px; color:#6b7280; font-weight:600; margin-bottom:8px; text-transform:uppercase; letter-spacing:.05em;">Фильтр по категориям</div>
                <div style="display:flex; flex-wrap:wrap; gap:6px;" id="categoryFilters">
                    <button type="button" class="cat-btn active" data-id=""
                            onclick="filterByCategory(this)"
                            style="padding:4px 12px; border-radius:20px; border:1.5px solid var(--accent,#2563eb);
                                   background:var(--accent,#2563eb); color:#fff; font-size:12px; font-weight:600; cursor:pointer;">
                        Все
                    </button>
                    @foreach (var cat in categories ?? new List<TagCategory>())
                    {
                        <button type="button" class="cat-btn" data-id="@cat.Id"
                                onclick="filterByCategory(this)"
                                style="padding:4px 12px; border-radius:20px; border:1.5px solid var(--border,#d1d5db);
                                       background:transparent; color:var(--text,#111); font-size:12px; font-weight:600; cursor:pointer;">
                            @cat.Name
                        </button>
                    }
                </div>
            </div>

            <!-- Список тегов -->
            <div class="tags-scroll" id="tagsContainer">
                @if (!grouped.Any())
                {
                    <p class="no-tags">Нет доступных тегов. Сначала создайте теги в разделе «Теги».</p>
                }
                else
                {
                    foreach (var g in grouped)
                    {
                        <div class="tag-group" data-id="@g.Value.First().TagCategoryTags.First().TagCategoryId">
                            <div class="tag-group-name">@g.Key</div>
                            <div class="tag-chips-row">
                                @foreach (var tag in g.Value)
                                {
                                    <label class="tag-chip-label" data-tag-id="@tag.Id">
                                        <input type="checkbox" name="tagIds" value="@tag.Id"
                                               class="tag-chip-cb" onchange="updateCount()" />
                                        @tag.Name
                                    </label>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <script>
            const filterButtons = document.querySelectorAll('.category-filter');
            const tagGroups = document.querySelectorAll('.tag-group');

            filterButtons.forEach(button => {
                button.addEventListener('click', function () {
                    const selectedCategory = this.dataset.category;

                    filterButtons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    tagGroups.forEach(group => {
                        const groupCategory = group.dataset.category;

                        if (selectedCategory === 'Все' || groupCategory === selectedCategory) {
                            group.style.display = 'block';
                        } else {
                            group.style.display = 'none';
                        }
                    });
                });
            });
        </script>
    </div>

    <div class="submit-bar">
        <a asp-action="Index" class="btn btn-ghost">Отмена</a>
        <button type="submit" class="btn btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
                <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/>
            </svg>
            Загрузить файл
        </button>
    </div>
</form>

<script>
function onFile(input) {
    if (input.files?.[0]) {
        document.getElementById('chosenName').textContent = input.files[0].name;
        const c = document.getElementById('fileChosen');
        c.style.display = 'flex';
        document.getElementById('dropZone').classList.add('has-file');
    }
}

function updateCount() {
    const n = document.querySelectorAll('.tag-chip-cb:checked').length;
    document.getElementById('countLabel').textContent = 'Выбрано: ' + n;
}

const selectedCategories = new Set();

function filterByCategory(btn) {
    const id = btn.dataset.id;

    if (id === '') {
        // "Все" — сбросить фильтр
        selectedCategories.clear();
        document.querySelectorAll('.cat-btn').forEach(b => {
            const isAll = b.dataset.id === '';
            b.style.background = isAll ? 'var(--accent,#2563eb)' : 'transparent';
            b.style.color = isAll ? '#fff' : 'var(--text,#111)';
            b.style.borderColor = isAll ? 'var(--accent,#2563eb)' : 'var(--border,#d1d5db)';
        });
        showAllTags();
        return;
    }

    // Переключить категорию
    if (selectedCategories.has(id)) {
        selectedCategories.delete(id);
        btn.style.background = 'transparent';
        btn.style.color = 'var(--text,#111)';
        btn.style.borderColor = 'var(--border,#d1d5db)';
    } else {
        selectedCategories.add(id);
        btn.style.background = 'var(--accent,#2563eb)';
        btn.style.color = '#fff';
        btn.style.borderColor = 'var(--accent,#2563eb)';
    }

    // Убрать подсветку с "Все"
    const allBtn = document.querySelector('.cat-btn[data-id=""]');
    allBtn.style.background = 'transparent';
    allBtn.style.color = 'var(--text,#111)';
    allBtn.style.borderColor = 'var(--border,#d1d5db)';

    if (selectedCategories.size === 0) {
        allBtn.style.background = 'var(--accent,#2563eb)';
        allBtn.style.color = '#fff';
        allBtn.style.borderColor = 'var(--accent,#2563eb)';
        showAllTags();
        return;
    }

    loadFilteredTags();
}

function showAllTags() {
    document.querySelectorAll('.tag-chip-label').forEach(l => l.style.display = '');
    document.querySelectorAll('.tag-group').forEach(g => g.style.display = '');
}

function loadFilteredTags() {
    const params = new URLSearchParams();
    selectedCategories.forEach(id => params.append('categoryIds', id));

    fetch('/api/tags/by-categories?' + params.toString())
        .then(r => r.json())
        .then(tags => {
            const allowedIds = new Set(tags.map(t => String(t.id)));

            document.querySelectorAll('.tag-chip-label').forEach(label => {
                label.style.display = allowedIds.has(label.dataset.tagId) ? '' : 'none';
            });

            // Скрыть группы где нет видимых тегов
            document.querySelectorAll('.tag-group').forEach(group => {
                const visible = group.querySelectorAll('.tag-chip-label:not([style*="none"])').length;
                group.style.display = visible > 0 ? '' : 'none';
            });

            updateCount();
        });
}

const dz = document.getElementById('dropZone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag-over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
dz.addEventListener('drop', e => {
    e.preventDefault(); dz.classList.remove('drag-over');
    const inp = document.getElementById('fileInput');
    if (e.dataTransfer.files.length) { inp.files = e.dataTransfer.files; onFile(inp); }
});
</script>

<script>
    function filterByCategory(btn) {
        const categoryId = btn.dataset.id;

        document.querySelectorAll('.cat-btn').forEach(b => {
            b.classList.remove('active');
            b.style.background = 'transparent';
            b.style.color = 'var(--text,#111)';
            b.style.borderColor = 'var(--border,#d1d5db)';
        });

        btn.classList.add('active');
        btn.style.background = 'var(--accent,#2563eb)';
        btn.style.color = '#fff';
        btn.style.borderColor = 'var(--accent,#2563eb)';

        document.querySelectorAll('.tag-group').forEach(group => {
            if (!categoryId || group.dataset.id == categoryId) {
                group.style.display = 'block';
            } else {
                group.style.display = 'none';
            }
        });
    }
</script>