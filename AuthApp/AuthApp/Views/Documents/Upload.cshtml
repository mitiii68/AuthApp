@{
    ViewData["Title"] = "Загрузка файла";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var tags = ViewBag.Tags as List<Tag>;
    var categories = ViewBag.Categories as List<TagCategory>;

    var grouped = tags?
        .GroupBy(t => t.TagCategoryTags?.FirstOrDefault()?.TagCategory?.Name ?? "Без категории")
        .ToDictionary(g => g.Key, g => g.ToList())
        ?? new Dictionary<string, List<Tag>>();
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Nunito...');

    :root {
        --accent:       #3b5bdb;
        --accent-light: #e7ecfd;
        --accent-hover: #2f4ac7;
        --surface:      #ffffff;
        --surface-2:    #f8f9fc;
        --border:       #e3e8f0;
        --text:         #1a1d2e;
        --text-sub:     #6b7280;
        --danger:       #e03131;
        --danger-light: #fff0f0;
        --success:      #2f9e44;
        --success-light:#ebfbee;
        --shadow-sm:    0 1px 4px rgba(59,91,219,.08);
        --shadow-md:    0 4px 20px rgba(59,91,219,.10);
        --radius:       12px;
        --font:         'Nunito', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font); color: var(--text); background: var(--surface-2); }

    
    .docs-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .docs-header h1 {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -.4px;
        line-height: 1.2;
    }
    .docs-header p {
        font-size: 14px;
        color: var(--text-sub);
        margin-top: 3px;
        font-weight: 500;
    }

    
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 8px;
        font-family: var(--font);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: background .15s, box-shadow .15s, transform .1s;
    }
    .btn:active { transform: scale(.98); }
    .btn-primary {
        background: var(--accent);
        color: #fff;
        box-shadow: 0 2px 8px rgba(59,91,219,.25);
    }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-ghost {
        background: var(--surface);
        color: var(--text);
        border: 1.5px solid var(--border);
    }
    .btn-ghost:hover { background: var(--surface-2); }

    
    .alert-error {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 18px;
        border-radius: var(--radius);
        border: 1.5px solid #fca5a5;
        background: var(--danger-light);
        color: var(--danger);
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    
    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }
    @@media (max-width: 768px) {
        .two-col {
            grid-template-columns: 1fr;
        }
    }

    
    .card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }
    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1.5px solid var(--border);
        font-size: 13.5px;
        font-weight: 700;
        color: var(--text);
        background: var(--surface-2);
    }
    .card-header-sub {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-sub);
    }

   
    .drop-zone {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 48px 24px;
        cursor: pointer;
        transition: background .15s, border-color .15s;
        min-height: 220px;
        text-align: center;
    }
    .drop-zone::before {
        content: '';
        position: absolute;
        inset: 16px;
        border: 2px dashed var(--border);
        border-radius: 10px;
        transition: border-color .15s;
        pointer-events: none;
    }
    .drop-zone:hover::before,
    .drop-zone.drag-over::before { border-color: var(--accent); }
    .drop-zone.drag-over { background: var(--accent-light); }
    .drop-zone.has-file::before { border-color: var(--success); border-style: solid; }
    .drop-zone.has-file { background: var(--success-light); }

    .drop-zone input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        width: 100%;
        height: 100%;
        cursor: pointer;
    }
    .drop-icon { color: var(--accent); opacity: .6; }
    .drop-zone.has-file .drop-icon { display: none; }
    .drop-text { font-size: 15px; font-weight: 700; color: var(--text); }
    .drop-hint { font-size: 12px; font-weight: 600; color: var(--text-sub); letter-spacing: .04em; }
    .file-chosen {
        display: none;
        align-items: center;
        gap: 8px;
        font-size: 13.5px;
        font-weight: 700;
        color: var(--success);
        background: #fff;
        border: 1.5px solid #a9e6b8;
        border-radius: 8px;
        padding: 8px 14px;
        max-width: 90%;
        word-break: break-all;
    }

    
    .category-filter-area {
        padding: 12px 16px;
        border-bottom: 1.5px solid var(--border);
        background: var(--surface-2);
    }
    .category-filter-label {
        font-size: 11px;
        color: var(--text-sub);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        margin-bottom: 8px;
    }
    .cat-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .cat-btn {
        padding: 4px 13px;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--text);
        font-family: var(--font);
        font-size: 12.5px;
        font-weight: 700;
        cursor: pointer;
        transition: background .12s, border-color .12s, color .12s;
    }
    .cat-btn:hover { border-color: var(--accent); color: var(--accent); }
    .cat-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }

   
    .tags-scroll {
        padding: 14px 16px;
        max-height: 300px;
        overflow-y: auto;
    }
    .no-tags { font-size: 13px; color: var(--text-sub); font-style: italic; }
    .tag-group { margin-bottom: 16px; }
    .tag-group:last-child { margin-bottom: 0; }
    .tag-group-name {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--text-sub);
        margin-bottom: 8px;
    }
    .tag-chips-row { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag-chip-label {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 13px;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: var(--surface-2);
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        cursor: pointer;
        transition: background .12s, border-color .12s, color .12s;
        user-select: none;
    }
    .tag-chip-label:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
    .tag-chip-label:has(.tag-chip-cb:checked) {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
    }
    .tag-chip-cb { display: none; }

    
    .submit-bar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 10px;
        padding-top: 4px;
    }
</style>


<div class="docs-header">
    <div>
        <h1>Загрузка файла</h1>
        <p>Добавьте документ в хранилище</p>
    </div>
    <a asp-action="Index" class="btn btn-ghost">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Назад
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        @ViewBag.Error
    </div>
}

<form asp-action="Upload" method="post" enctype="multipart/form-data">
    <div class="two-col">


        <div class="card">
            <div class="card-header">Файл</div>
            <div class="drop-zone" id="dropZone">
                <input type="file" name="file" id="fileInput" required
                       accept=".doc,.docx,.xls,.xlsx,.pdf,.zip,.rar,.7z"
                       onchange="onFile(this)" />
                <div class="drop-icon">
                    <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
                        <polyline points="16 16 12 12 8 16"/>
                        <line x1="12" y1="12" x2="12" y2="21"/>
                        <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/>
                    </svg>
                </div>
                <div class="drop-text">Нажмите или перетащите файл</div>
                <div class="drop-hint">DOC · DOCX · XLS · XLSX · PDF · ZIP · RAR · 7Z</div>
                <div class="file-chosen" id="fileChosen">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <span id="chosenName"></span>
                </div>
            </div>
        </div>

       
        <div class="card">
            <div class="card-header">
                <span>Теги</span>
                <span class="card-header-sub" id="countLabel">Выбрано: 0</span>
            </div>

            <div class="category-filter-area">
                <div class="category-filter-label">Категория</div>
                <div class="cat-chips">
                    <button type="button" class="cat-btn active" data-id="" onclick="filterByCategory(this)">Все</button>
                    @foreach (var cat in categories ?? new List<TagCategory>())
                    {
                        <button type="button" class="cat-btn" data-id="@cat.Id" onclick="filterByCategory(this)">@cat.Name</button>
                    }
                </div>
            </div>

            <div class="tags-scroll" id="tagsContainer">
                @if (!grouped.Any())
                {
                    <p class="no-tags">Нет доступных тегов. Сначала создайте теги в разделе «Теги».</p>
                }
                else
                {
                    foreach (var g in grouped)
                    {
                        <div class="tag-group" data-id="@g.Value.First().TagCategoryTags.First().TagCategoryId">
                            <div class="tag-group-name">@g.Key</div>
                            <div class="tag-chips-row">
                                @foreach (var tag in g.Value)
                                {
                                    <label class="tag-chip-label" data-tag-id="@tag.Id">
                                        <input type="checkbox" name="tagIds" value="@tag.Id"
                                               class="tag-chip-cb" onchange="updateCount()" />
                                        @tag.Name
                                    </label>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="submit-bar">
        <a asp-action="Index" class="btn btn-ghost">Отмена</a>
        <button type="submit" class="btn btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
                <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/>
            </svg>
            Загрузить файл
        </button>
    </div>
</form>

<script>
function onFile(input) {
    if (input.files?.[0]) {
        document.getElementById('chosenName').textContent = input.files[0].name;
        document.getElementById('fileChosen').style.display = 'flex';
        document.getElementById('dropZone').classList.add('has-file');
    }
}

function updateCount() {
    const n = document.querySelectorAll('.tag-chip-cb:checked').length;
    document.getElementById('countLabel').textContent = 'Выбрано: ' + n;
}

function filterByCategory(btn) {
    const categoryId = btn.dataset.id;

    document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    document.querySelectorAll('.tag-group').forEach(group => {
        group.style.display = (!categoryId || group.dataset.id == categoryId) ? '' : 'none';
    });
}

const dz = document.getElementById('dropZone');
dz.addEventListener('dragover',  e => { e.preventDefault(); dz.classList.add('drag-over'); });
dz.addEventListener('dragleave', ()  => dz.classList.remove('drag-over'));
dz.addEventListener('drop',      e  => {
    e.preventDefault();
    dz.classList.remove('drag-over');
    const inp = document.getElementById('fileInput');
    if (e.dataTransfer.files.length) { inp.files = e.dataTransfer.files; onFile(inp); }
});
</script>
